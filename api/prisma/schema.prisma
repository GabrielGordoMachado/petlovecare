// learn more about it in the docs: https://pris.ly/d/prisma-schema

// PetLoveCare System — Prisma Schema
// Disciplina: APSOO — Análise e Projeto de Sistemas Orientados a Objetos
// Versão: 1.0 — 28/05/2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USUÁRIOS
// ─────────────────────────────────────────────

model Cliente {
  cpf      String @id @db.VarChar(11)
  nome     String @db.VarChar(100)
  telefone String @db.VarChar(15)
  email    String @unique @db.VarChar(100)
  senha    String @db.VarChar(255)

  pets          Pet[]
  agendamentos  Agendamento[]
  feedbacks     Feedback[]

  @@map("cliente")
}

model Administrador {
  cpf      String @id @db.VarChar(11)
  nome     String @db.VarChar(100)
  telefone String @db.VarChar(15)
  email    String @unique @db.VarChar(100)
  senha    String @db.VarChar(255)

  agendamentos  Agendamento[]  @relation("AdminAgendamento")
  servicos      Servico[]
  feedbacks     Feedback[]     @relation("AdminFeedback")

  @@map("administrador")
}

// ─────────────────────────────────────────────
// PET
// ─────────────────────────────────────────────

model Pet {
  id           Int    @id @default(autoincrement())
  cliente_cpf  String @db.VarChar(11)
  nomePet      String @db.VarChar(50)
  especie      String @db.VarChar(30)
  raca         String @db.VarChar(50)
  idade        Int
  observacoes  String? @db.Text

  cliente      Cliente       @relation(fields: [cliente_cpf], references: [cpf])
  agendamentos Agendamento[]

  @@map("pet")
}

// ─────────────────────────────────────────────
// SERVIÇO
// ─────────────────────────────────────────────

model Servico {
  id          Int     @id @default(autoincrement())
  admin_cpf   String  @db.VarChar(11)
  nome        String  @db.VarChar(100)
  descricao   String? @db.Text
  preco       Decimal @db.Decimal(10, 2)
  duracao     Int     // duração em minutos

  administrador       Administrador        @relation(fields: [admin_cpf], references: [cpf])
  agendamentoServico  AgendamentoServico[]

  @@map("servico")
}

// ─────────────────────────────────────────────
// AGENDAMENTO
// ─────────────────────────────────────────────

enum StatusAgendamento {
  agendado
  em_andamento
  finalizado
  cancelado
}

model Agendamento {
  id           Int                @id @default(autoincrement())
  cliente_cpf  String             @db.VarChar(11)
  pet_id       Int
  admin_cpf    String?            @db.VarChar(11) // nullable: preenchido ao aprovar/recusar
  data_hora    DateTime
  status       StatusAgendamento  @default(agendado)
  observacao   String?            @db.Text

  cliente            Cliente              @relation(fields: [cliente_cpf], references: [cpf])
  pet                Pet                  @relation(fields: [pet_id], references: [id])
  administrador      Administrador?       @relation("AdminAgendamento", fields: [admin_cpf], references: [cpf])
  agendamentoServico AgendamentoServico[]
  feedback           Feedback?

  @@map("agendamento")
}

// ─────────────────────────────────────────────
// AGENDAMENTO_SERVICO (N:M)
// Regra RN01: máximo 2 serviços por agendamento (validado na API)
// ─────────────────────────────────────────────

model AgendamentoServico {
  agendamento_id Int
  servico_id     Int

  agendamento Agendamento @relation(fields: [agendamento_id], references: [id])
  servico     Servico     @relation(fields: [servico_id], references: [id])

  @@id([agendamento_id, servico_id])
  @@map("agendamento_servico")
}

// ─────────────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────────────

model Feedback {
  id             Int      @id @default(autoincrement())
  agendamento_id Int      @unique // 1 feedback por agendamento
  cliente_cpf    String   @db.VarChar(11)
  admin_cpf      String?  @db.VarChar(11) // nullable: preenchido ao responder
  nota           Int      // 1 a 5
  comentario     String   @db.Text
  data           DateTime @default(now())
  resposta       String?  @db.Text

  agendamento   Agendamento    @relation(fields: [agendamento_id], references: [id])
  cliente       Cliente        @relation(fields: [cliente_cpf], references: [cpf])
  administrador Administrador? @relation("AdminFeedback", fields: [admin_cpf], references: [cpf])

  @@map("feedback")
}
